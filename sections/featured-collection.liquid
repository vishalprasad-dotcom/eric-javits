<!-- Slick CSS -->
{{ 'https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.css' | stylesheet_tag }}
{{ 'https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick-theme.min.css' | stylesheet_tag }}

<!-- jQuery (if not already loaded) -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<!-- Slick JS -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.js"></script>

<section>
  <div class="featured-collection-container">
    <div class="collection-wrapper">
    <h2>{{ section.settings.featured_collection_heading }}</h2>

    {% assign collection = collections[section.settings.collection] %}
    <div class="slider-container">
      {% for product in collection.products %}
        <div class="slide">
          <a href="{{ product.url }}">
            <img src="{{ product.featured_image | img_url: 'master' }}">
            <p class="prod-title">{{ product.title }}</p>
            <p class="prod-price">{{ product.price | money }}</p>
          </a>
        </div>
      {% endfor %}
    </div>
    </div>
  </div>
</section>
<script>
  document.addEventListener("DOMContentLoaded", function(){
    if (typeof jQuery !== "undefined" && jQuery.fn.slick){
      $('.slider-container').slick({
        slidesToShow: 3,
        slidesToScroll: 1,
        infinite: true,
        arrows: true,
        responsive:[
          { 
            breakpoint: 1200,
            settings: {
              slidesToShow: 2
            }
          },
          { 
            breakpoint: 990,
            settings: {
              slidesToShow: 2
            }
          },
          {
            breakpoint: 767,
            settings: {
              slidesToShow: 1
            }
          }
        ]
      })
    }
  })
</script>
{% schema %}
{
  "name": "t:sections.featured-collection.name",
  "tag": "section",
  "class": "featured-collection-section",
  "settings": [
    {
      "type": "text",
      "id": "featured_collection_heading",
      "label": "Heading"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Choose collection"
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured-collection.presets.name"
    }
  ]
}
{% endschema %}
